<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Flock Alert</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.flockalert.app</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Flock Alert</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Take photos of cameras when submitting community reports to help verify locations.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Flock Alert uses your location to alert you as you approach documented surveillance cameras. Your location is never sent to our servers.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Flock Alert monitors for nearby surveillance cameras in the background so you can receive alerts while driving.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Flock Alert shows surveillance cameras near your current location.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Accessed as part of camera functionality when taking report photos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Select photos from your library to attach to camera reports.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>location-services</string>
		<string>gps</string>
	</array>
</dict>
</plist>
